						<h2 class="card-title">MongoDB Express</h2>
						<div class="status-dot" data-dot-for="mongo-express"></div>
					</div>
					<p class="card-desc">MongoDB Web GUI</p>
					<div class="card-stats">
						<div class="stats-row">
							<div class="card-stats-col"><span class="card-stats-label">CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
