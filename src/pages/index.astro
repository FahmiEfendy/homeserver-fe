		</div>

		<script>
			// Add loading class to all sparklines initially
			document.querySelectorAll('.sparkline').forEach(el => el.classList.add('loading'));

			// Rolling telemetry history state
			const history = {
				server: {
					cpu: [],
					ram: [],
					temp: []
				},
				containers: {} // keyed by lowercase container name, e.g. "fe-homeserver": { cpu: [], mem: [] }
			};

			// Render inline SVG sparkline helper
			function updateSparkline(svgElement, values, color = '#22c55e') {
				if (!svgElement || !values || values.length < 2) return;
				
				svgElement.classList.remove('loading');
				
				let min = Math.min(...values);
				let max = Math.max(...values);
				if (max - min < 1) {
					max = min + 1; // Ensure some range to avoid division by zero or flat scale
				}
				const range = max - min;
				
				const points = values.map((val, index) => {
					const x = (index / (values.length - 1)) * 100;
					const y = 22 - ((val - min) / range) * 20; // 2px margin top/bottom inside 24px height
					return { x, y };
				});
				
				const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
				const fillPath = `${linePath} L 100 24 L 0 24 Z`;
				
				// Generate unique ID for linearGradient to avoid conflicts
				const gradId = 'grad-' + Math.random().toString(36).substr(2, 9);
				
				svgElement.innerHTML = `
					<defs>
						<linearGradient id="${gradId}" x1="0" y1="0" x2="0" y2="1">
							<stop offset="0%" stop-color="${color}" stop-opacity="0.15"/>
							<stop offset="100%" stop-color="${color}" stop-opacity="0.0"/>
						</linearGradient>
					</defs>
					<path d="${fillPath}" fill="url(#${gradId})"></path>
					<path d="${linePath}" fill="none" stroke="${color}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
				`;
			}

			async function fetchVitals() {
				try {
					const apiUrl = import.meta.env.PUBLIC_API_BASE_URL + '/vitals';
					
					const res = await fetch(apiUrl);
					const data = await res.json();
					
					document.getElementById('cpu-load').textContent = data.cpuLoad;
					document.getElementById('ram-used').textContent = data.ramUsed;
					document.getElementById('ram-total').textContent = data.ramTotal;
					document.getElementById('disk-usage').textContent = data.disk;
					document.getElementById('temp').textContent = data.temp;

					// Update disk progress bar
					const diskPerc = parseInt(data.disk);
					const diskBarFill = document.getElementById('disk-bar-fill');
					if (!isNaN(diskPerc) && diskBarFill) {
						diskBarFill.style.width = diskPerc + '%';
					}

					// Push CPU vitals
					const cpuVal = parseFloat(data.cpuLoad);
					if (!isNaN(cpuVal)) {
						history.server.cpu.push(cpuVal);
						if (history.server.cpu.length > 12) history.server.cpu.shift();
						updateSparkline(document.getElementById('cpu-sparkline'), history.server.cpu, '#22c55e');
					}

					// Push RAM vitals
					const ramUsedVal = parseFloat(data.ramUsed);
					const ramTotalVal = parseFloat(data.ramTotal);
					if (!isNaN(ramUsedVal) && !isNaN(ramTotalVal) && ramTotalVal > 0) {
						const ramPerc = (ramUsedVal / ramTotalVal) * 100;
						history.server.ram.push(ramPerc);
						if (history.server.ram.length > 12) history.server.ram.shift();
						updateSparkline(document.getElementById('ram-sparkline'), history.server.ram, '#3b82f6');
					}

					// Push Temp vitals
					const tempVal = parseFloat(data.temp);
					if (!isNaN(tempVal)) {
						history.server.temp.push(tempVal);
						if (history.server.temp.length > 12) history.server.temp.shift();
						updateSparkline(document.getElementById('temp-sparkline'), history.server.temp, '#f97316');
					}
				} catch (err) {
					console.error('Failed to fetch vitals', err);
				}
			}
			
			async function fetchDockerStats() {
				try {
					const apiUrl = import.meta.env.PUBLIC_API_BASE_URL + '/docker';
					
					const res = await fetch(apiUrl);
					const data = await res.json();
					
					if (data.error || data.length === 0) return;
					
					// Map stats to corresponding nodes
					const statNodes = document.querySelectorAll('[data-container]');
					statNodes.forEach(node => {
						const containerMatch = node.getAttribute('data-container');
						// Find a matching docker container (try exact match first, then fallback to includes)
						const stat = data.find(s => s.Name.toLowerCase() === containerMatch.toLowerCase())
							|| data.find(s => s.Name.toLowerCase().includes(containerMatch.toLowerCase()));
						
						if (stat) {
							if(node.querySelector('.stat-cpu')) node.querySelector('.stat-cpu').textContent = stat.CPUPerc;
							if(node.querySelector('.stat-mem')) node.querySelector('.stat-mem').textContent = stat.MemUsage.split(' / ')[0];
							if(node.querySelector('.stat-mem-perc')) node.querySelector('.stat-mem-perc').textContent = stat.MemPerc;
							if(node.querySelector('.stat-uptime')) node.querySelector('.stat-uptime').textContent = stat.Status;

							// Update container sparkline history
							const cpuVal = parseFloat(stat.CPUPerc);
							const memVal = parseFloat(stat.MemPerc);
							const cName = stat.Name.toLowerCase();
							
							if (!history.containers[cName]) {
								history.containers[cName] = { cpu: [], mem: [] };
							}
							
							if (!isNaN(cpuVal)) {
								history.containers[cName].cpu.push(cpuVal);
								if (history.containers[cName].cpu.length > 12) history.containers[cName].cpu.shift();
								const cpuSvg = node.querySelector('.container-sparkline-cpu');
								if (cpuSvg) updateSparkline(cpuSvg, history.containers[cName].cpu, '#22c55e');
							}
							
							if (!isNaN(memVal)) {
								history.containers[cName].mem.push(memVal);
								if (history.containers[cName].mem.length > 12) history.containers[cName].mem.shift();
								const memSvg = node.querySelector('.container-sparkline-mem');
								if (memSvg) updateSparkline(memSvg, history.containers[cName].mem, '#3b82f6');
							}
						}
					});
					
					// Update dynamic health dots
					const dots = document.querySelectorAll('.status-dot[data-dot-for]');
					dots.forEach(dot => {
						const containerMatch = dot.getAttribute('data-dot-for');
						const stat = data.find(s => s.Name.toLowerCase() === containerMatch.toLowerCase())
							|| data.find(s => s.Name.toLowerCase().includes(containerMatch.toLowerCase()));
						if (stat && stat.Status.startsWith('Up')) {
							dot.style.backgroundColor = 'var(--accent-online)';
						} else {
							dot.style.backgroundColor = '#ef4444';
						}
					});
				} catch (err) {
					console.error('Failed to fetch docker stats', err);
				}
			}
			
			// Handle Toggles
			const toggle = document.getElementById('stats-toggle');
			toggle.addEventListener('change', (e) => {
				const statsBlocks = document.querySelectorAll('.card-stats');
				statsBlocks.forEach(block => {
					if (e.target.checked) {
						block.classList.add('visible');
					} else {
						block.classList.remove('visible');
					}
				});
			});

			const vitalsToggle = document.getElementById('vitals-toggle');
			vitalsToggle.addEventListener('change', (e) => {
				const vitalsBar = document.getElementById('vitals-bar');
				if (e.target.checked) {
					vitalsBar.classList.add('show-charts');
				} else {
					vitalsBar.classList.remove('show-charts');
				}
			});
			
			// Fetch immediately and then every 5 seconds
			fetchVitals();
			fetchDockerStats();
			setInterval(() => {
				fetchVitals();
				fetchDockerStats();
			}, 5000);
		</script>
	</body>
