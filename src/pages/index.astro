---
const baseDomain = import.meta.env.BASE_DOMAIN || 'fahmiefendy.dev';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>fahmi homeserver.</title>
		<style>
			:root {
				--bg-color: #121212;
				--card-bg: #1a1a1a;
				--text-main: #f0f0f0;
				--text-muted: #888888;
				--border-color: #2a2a2a;
				--accent-online: #22c55e;
			}
			body {
				background-color: var(--bg-color);
				color: var(--text-main);
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
				margin: 0;
				padding: 60px 20px;
				display: flex;
				justify-content: center;
			}
			.container {
				max-width: 800px;
				width: 100%;
			}
			h1 {
				font-size: 1.5rem;
				font-weight: 600;
				margin-top: 0;
				margin-bottom: 1.5rem;
				letter-spacing: -0.02em;
			}
			.vitals-toggle-wrapper {
				display: flex;
				align-items: center;
				gap: 8px;
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 1.5rem;
			}
			.section-title {
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--text-muted);
				margin-bottom: 1rem;
				margin-top: 2.5rem;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 16px;
			}
			.card {
				background-color: var(--card-bg);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 20px;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				transition: border-color 0.2s ease;
			}
			.card:hover {
				border-color: #555;
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 6px;
			}
			.card-title {
				font-size: 0.95rem;
				font-weight: 500;
				margin: 0;
			}
			.status-dots {
				display: flex;
				gap: 8px;
			}
			.dot-wrapper {
				display: flex;
				align-items: center;
				gap: 4px;
			}
			.dot-label {
				font-size: 0.65rem;
				color: var(--text-muted);
				font-family: monospace;
			}
			.status-dot {
				width: 8px;
				height: 8px;
				background-color: #444; /* Default offline/unknown gray */
				border-radius: 50%;
				transition: background-color 0.3s ease;
			}
			.card-desc {
				font-size: 0.85rem;
				color: var(--text-muted);
				margin: 0;
			}
			
			.vitals-bar {
				display: flex;
				gap: 20px;
				margin-bottom: 2rem;
				font-size: 0.85rem;
				color: var(--text-muted);
				background-color: var(--card-bg);
				padding: 12px 16px;
				border-radius: 6px;
				border: 1px solid var(--border-color);
				flex-wrap: wrap;
				align-items: center;
				transition: all 0.3s ease;
			}
			.vitals-bar.show-charts {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 16px;
				align-items: stretch;
				padding: 16px;
			}
			.vital {
				display: flex;
				align-items: center;
				gap: 6px;
				transition: all 0.3s ease;
				width: auto;
				box-sizing: border-box;
			}
			.vitals-bar.show-charts .vital {
				flex-direction: column;
				align-items: flex-start;
				gap: 8px;
				background-color: rgba(255, 255, 255, 0.02);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 16px;
				width: 100%;
			}
			.vital div {
				white-space: nowrap;
			}
			.vital span {
				color: var(--text-main);
				font-family: monospace;
				font-size: 0.9rem;
				font-weight: 500;
			}
			.sparkline {
				display: inline-block;
				vertical-align: middle;
			}
			.sparkline.loading {
				background: linear-gradient(90deg, rgba(255, 255, 255, 0.03) 25%, rgba(255, 255, 255, 0.08) 50%, rgba(255, 255, 255, 0.03) 75%);
				background-size: 200% 100%;
				animation: shimmer 1.5s infinite linear;
				border-radius: 4px;
			}
			@keyframes shimmer {
				0% {
					background-position: 200% 0;
				}
				100% {
					background-position: -200% 0;
				}
			}
			.vitals-bar .sparkline {
				width: 48px;
				height: 16px;
				display: none; /* Hidden by default */
			}
			.vitals-bar.show-charts .sparkline {
				display: block;
				width: 100%;
				height: 40px;
				margin-top: 8px;
			}
			.disk-bar-container {
				width: 100%;
				height: 6px;
				background-color: rgba(255, 255, 255, 0.1);
				border-radius: 3px;
				overflow: hidden;
				display: none;
				margin-top: 25px;
			}
			.vitals-bar.show-charts .disk-bar-container {
				display: block;
			}
			.disk-bar-fill {
				height: 100%;
				width: 0%;
				background-color: #a855f7;
				border-radius: 3px;
				transition: width 0.3s ease;
			}
			
			.toggle-container {
				display: flex;
				align-items: center;
				gap: 24px;
				margin-bottom: 2rem;
				font-size: 0.85rem;
				color: var(--text-muted);
			}
			.toggle-switch {
				position: relative;
				display: inline-block;
				width: 40px;
				height: 20px;
			}
			.toggle-switch input {
				opacity: 0;
				width: 0;
				height: 0;
			}
			.slider {
				position: absolute;
				cursor: pointer;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background-color: var(--border-color);
				transition: .2s;
				border-radius: 20px;
			}
			.slider:before {
				position: absolute;
				content: "";
				height: 14px;
				width: 14px;
				left: 3px;
				bottom: 3px;
				background-color: var(--text-muted);
				transition: .2s;
				border-radius: 50%;
			}
			input:checked + .slider {
				background-color: var(--accent-online);
			}
			input:checked + .slider:before {
				transform: translateX(20px);
				background-color: #fff;
			}
			
			.card-stats {
				max-height: 0;
				opacity: 0;
				overflow: hidden;
				transition: max-height 0.3s ease, opacity 0.3s ease, margin-top 0.3s ease, padding-top 0.3s ease;
				margin-top: 0;
				padding-top: 0;
				border-top: 1px solid transparent;
				font-size: 0.8rem;
				color: var(--text-muted);
				font-family: monospace;
				display: flex;
				flex-direction: column;
				gap: 10px;
			}
			.card-stats.visible {
				max-height: 200px;
				opacity: 1;
				margin-top: 15px;
				padding-top: 15px;
				border-top-color: var(--border-color);
			}
			.stats-row {
				display: flex;
				justify-content: space-between;
				width: 100%;
				align-items: flex-start;
				gap: 12px;
			}
			.card-stats-col {
				display: flex;
				flex-direction: column;
				gap: 4px;
				align-items: flex-start;
				flex: 1;
				min-width: 0;
			}
			.card-stats-col .sparkline {
				width: 100%;
				max-width: 80px;
				height: 18px;
				margin-top: 2px;
			}
			.card-stats-label {
				font-size: 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				opacity: 0.7;
			}
			.card-stats-val {
				color: var(--text-main);
			}
			/* Mobile Responsiveness */
			@media (max-width: 600px) {
				body {
					padding: 30px 16px;
				}
				.grid {
					grid-template-columns: 1fr;
					gap: 12px;
				}
				h1 {
					font-size: 1.3rem;
					margin-bottom: 1rem;
				}
				.vitals-bar.show-charts {
					grid-template-columns: repeat(2, 1fr);
					gap: 12px;
					padding: 12px;
				}
				.vitals-bar.show-charts .vital {
					padding: 12px;
				}
				.disk-bar-container {
					margin-top: 25px;
				}
				.section-title {
					margin-top: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<div class="container">
			<h1>fahmi homeserver.</h1>

			<div class="vitals-toggle-wrapper">
				<label class="toggle-switch">
					<input type="checkbox" id="vitals-toggle">
					<span class="slider"></span>
				</label>
				<span>Show Vitals Charts</span>
			</div>

			<div class="vitals-bar" id="vitals-bar">
				<div class="vital">
					<div>CPU: <span id="cpu-load">...</span>%</div>
					<svg class="sparkline" id="cpu-sparkline" viewBox="0 0 100 24" preserveAspectRatio="none"></svg>
				</div>
				<div class="vital">
					<div>RAM <span id="ram-used">...</span> / <span id="ram-total">...</span> GB</div>
					<svg class="sparkline" id="ram-sparkline" viewBox="0 0 100 24" preserveAspectRatio="none"></svg>
				</div>
				<div class="vital">
					<div>DISK: <span id="disk-usage">...</span></div>
					<div class="disk-bar-container"><div class="disk-bar-fill" id="disk-bar-fill"></div></div>
				</div>
				<div class="vital">
					<div>TEMP: <span id="temp">...</span></div>
					<svg class="sparkline" id="temp-sparkline" viewBox="0 0 100 24" preserveAspectRatio="none"></svg>
				</div>
			</div>
			
			<div class="toggle-container">
				<div style="display: flex; align-items: center; gap: 8px;">
					<label class="toggle-switch">
						<input type="checkbox" id="stats-toggle">
						<span class="slider"></span>
					</label>
					<span>Show Container Stats</span>
				</div>
			</div>

			<div class="section-title">Public Apps</div>
			<div class="grid">
				<a href={`https://dashboard.${baseDomain}`} class="card" target="_blank">
					<div class="card-header">
						<h2 class="card-title">Homeserver Dashboard</h2>
						<div class="status-dots">
							<div class="dot-wrapper">
								<span class="dot-label">FE</span>
								<div class="status-dot" data-dot-for="fe-homeserver"></div>
							</div>
							<div class="dot-wrapper">
								<span class="dot-label">BE</span>
								<div class="status-dot" data-dot-for="be-homeserver"></div>
							</div>
						</div>
					</div>
					<p class="card-desc">System dashboard and analytics gateway</p>
					<div class="card-stats">
						<div class="stats-row" data-container="fe-homeserver">
							<div class="card-stats-col"><span class="card-stats-label">FE CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
						<div class="stats-row" data-container="be-homeserver">
							<div class="card-stats-col"><span class="card-stats-label">BE CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
					</div>
				</a>
				<a href={`https://wine.${baseDomain}/`} class="card" target="_blank">
					<div class="card-header">
						<h2 class="card-title">The Wine Corner</h2>
						<div class="status-dots">
							<div class="dot-wrapper">
								<span class="dot-label">FE</span>
								<div class="status-dot" data-dot-for="twc-fe"></div>
							</div>
							<div class="dot-wrapper">
								<span class="dot-label">BE</span>
								<div class="status-dot" data-dot-for="twc-be"></div>
							</div>
						</div>
					</div>
					<p class="card-desc">Your personal AI sommelier and wine catalog</p>
					<div class="card-stats">
						<div class="stats-row" data-container="twc-fe">
							<div class="card-stats-col"><span class="card-stats-label">FE CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
						<div class="stats-row" data-container="twc-be">
							<div class="card-stats-col"><span class="card-stats-label">BE CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
					</div>
				</a>
				<a href={`https://places.${baseDomain}`} class="card" target="_blank">
					<div class="card-header">
						<h2 class="card-title">Your Places</h2>
						<div class="status-dots">
							<div class="dot-wrapper">
								<span class="dot-label">FE</span>
								<div class="status-dot" data-dot-for="yp-fe"></div>
							</div>
							<div class="dot-wrapper">
								<span class="dot-label">BE</span>
								<div class="status-dot" data-dot-for="yp-be"></div>
							</div>
						</div>
					</div>
					<p class="card-desc">Location tracking and maps</p>
					<div class="card-stats">
						<div class="stats-row" data-container="yp-fe">
							<div class="card-stats-col"><span class="card-stats-label">FE CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
						<div class="stats-row" data-container="yp-be">
							<div class="card-stats-col"><span class="card-stats-label">BE CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
					</div>
				</a>
			</div>

			<div class="section-title">Internal Tools</div>
			<div class="grid">
				<a href={`https://analytics.${baseDomain}`} class="card" target="_blank" data-container="main-dashboard">
					<div class="card-header">
						<h2 class="card-title">GoAccess</h2>
						<div class="status-dot" data-dot-for="main-dashboard"></div>
					</div>
					<p class="card-desc">NGINX Server Analytics</p>
					<div class="card-stats">
						<div class="stats-row">
							<div class="card-stats-col"><span class="card-stats-label">CPU%</span><span class="stat-cpu card-stats-val">--%</span><svg class="sparkline container-sparkline-cpu" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM%</span><span class="stat-mem-perc card-stats-val">--%</span><svg class="sparkline container-sparkline-mem" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
							<div class="card-stats-col"><span class="card-stats-label">MEM</span><span class="stat-mem card-stats-val">--</span></div>
							<div class="card-stats-col"><span class="card-stats-label">UPTIME</span><span class="stat-uptime card-stats-val">--</span></div>
						</div>
					</div>
				</a>
				<a href={`https://mongo.${baseDomain}`} class="card" target="_blank" data-container="mongo-express">
